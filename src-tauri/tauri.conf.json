{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FFmpeg Forge",
  "version": "0.1.0",
  "identifier": "com.nordik.ffmpegforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FFmpeg Forge",
        "width": 1500,
        "height": 1020,
        "minWidth": 1180,
        "minHeight": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "shortDescription": "Desktop FFmpeg GUI",
    "copyright": "Copyright (c) 2026"
  }
}
