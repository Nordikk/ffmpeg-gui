{
  "name": "ffmpeggui",
  "productName": "FFmpeg Forge",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop GUI fuer FFmpeg-Workflows wie Convert, Lossless Cut und Batch-Jobs.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start:desktop": "npm run build && electron .",
    "build:desktop": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.nordik.ffmpegforge",
    "productName": "FFmpeg Forge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}",
      "signAndEditExecutable": false
    }
  }
}
