{
  "name": "ffmpeggui",
  "productName": "FFForge",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop GUI for FFmpeg workflows such as convert, lossless cut, and batch jobs.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:build:mac": "tauri build --bundles app",
    "tauri:build:windows": "tauri build --bundles nsis"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
